{
  "name": "@cffnpwr/commitlint-config",
  "version": "1.0.1",
  "private": false,
  "description": "Common commitlint configuration for cffnpwr",
  "homepage": "https://github.com/cffnpwr/commitlint-config",
  "bugs": "https://github.com/cffnpwr/commitlint-config/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/cffnpwr/commitlint-config.git"
  },
  "license": "MIT",
  "author": "cffnpwr",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist node_modules",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "devDependencies": {
    "@cffnpwr/eslint-config": "2.0.1",
    "@cffnpwr/tsconfig": "1.0.0",
    "@commitlint/types": "21.2.0",
    "@types/bun": "1.3.14",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "eslint-config-flat-gitignore": "2.3.0",
    "globals": "17.7.0",
    "jsr": "0.14.3",
    "pnpm": "10.34.5",
    "tsdown": "0.22.12",
    "typescript": "6.0.3"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "inlinedDependencies": {
    "@commitlint/types": "21.2.0",
    "conventional-commits-parser": "7.0.1"
  }
}
